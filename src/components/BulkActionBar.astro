---
---

<div
  class="BulkActionBar"
  id="bulk-action-bar"
  role="group"
  aria-label="Bulk actions for selected vendors"
  hidden
>
  <span class="BulkActionBar__count">
    <strong id="bulk-selected-count">0</strong> selected
  </span>
  <div class="BulkActionBar__actions">
    <button
      type="button"
      class="BulkActionBar__btn BulkActionBar__btn--approve"
      id="bulk-approve"
    >
      Approve
    </button>
    <button
      type="button"
      class="BulkActionBar__btn BulkActionBar__btn--reject"
      id="bulk-reject"
    >
      Reject
    </button>
    <button
      type="button"
      class="BulkActionBar__btn BulkActionBar__btn--waitlist"
      id="bulk-waitlist"
    >
      Waitlist
    </button>
    <button
      type="button"
      class="BulkActionBar__btn BulkActionBar__btn--export"
      id="bulk-export"
      aria-label="Export selected vendors to CSV"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
      Export CSV
    </button>
    <button
      type="button"
      class="BulkActionBar__btn BulkActionBar__btn--clear"
      id="bulk-clear"
    >
      Clear selection
    </button>
  </div>
</div>

<style is:global>
  .BulkActionBar {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.75rem 1rem;
    background: var(--teal);
    border-radius: var(--radius-sm);
    color: var(--white);
    margin-bottom: 0.75rem;
    flex-wrap: wrap;

    &[hidden] {
      display: none;
    }
  }

  .BulkActionBar__count {
    font: 400 0.9375rem / 1.5 var(--font);
    white-space: nowrap;

    strong {
      font-weight: 700;
    }
  }

  .BulkActionBar__actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .BulkActionBar__btn {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.375rem 0.875rem;
    border-radius: var(--radius-pill);
    font: 500 0.875rem / 1.5 var(--font);
    border: 1.5px solid rgba(255, 255, 255, 0.4);
    color: var(--white);
    background: rgba(255, 255, 255, 0.1);
    transition: background var(--transition), border-color var(--transition);

    &:hover {
      background: rgba(255, 255, 255, 0.25);
      border-color: rgba(255, 255, 255, 0.7);
    }

    &:focus-visible {
      outline: 2px solid var(--white);
      outline-offset: 2px;
    }
  }

  .BulkActionBar__btn--waitlist {
    background: rgba(255, 255, 255, 0.15);
    border-color: rgba(255, 255, 255, 0.5);
  }

  .BulkActionBar__btn--export {
    background: rgba(255, 255, 255, 0.2);
    border-color: rgba(255, 255, 255, 0.6);
  }

  .BulkActionBar__btn--clear {
    background: transparent;
    border-color: transparent;
    text-decoration: underline;
    text-underline-offset: 2px;

    &:hover {
      background: transparent;
      border-color: transparent;
    }
  }
</style>
