---
interface Props {
  activePage?: "applications" | "events" | "reports";
}

const { activePage = "applications" } = Astro.props;
---

<header class="AppHeader">
  <div class="AppHeader__inner">
    <div class="AppHeader__brand">
      <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 32 32" aria-hidden="true"><rect width="32" height="32" rx="6" fill="white" fill-opacity="0.2"/><text x="16" y="22" text-anchor="middle" font-family="sans-serif" font-size="18" font-weight="700" fill="white">E</text></svg>
      <span class="AppHeader__brand-name">Eventeny</span>
    </div>
    <nav class="AppHeader__nav" aria-label="Main navigation">
      <a
        href={import.meta.env.BASE_URL}
        class={`AppHeader__nav-link${activePage === "applications" ? " AppHeader__nav-link--active" : ""}`}
        aria-current={activePage === "applications" ? "page" : undefined}
      >Applications</a>
      <a
        href={import.meta.env.BASE_URL}
        class={`AppHeader__nav-link${activePage === "events" ? " AppHeader__nav-link--active" : ""}`}
        aria-current={activePage === "events" ? "page" : undefined}
      >Events</a>
      <a
        href={import.meta.env.BASE_URL}
        class={`AppHeader__nav-link${activePage === "reports" ? " AppHeader__nav-link--active" : ""}`}
        aria-current={activePage === "reports" ? "page" : undefined}
      >Reports</a>
    </nav>
    <div class="AppHeader__user" aria-label="Logged in as Organizer">
      <span class="AppHeader__user-avatar" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
      </span>
      <span class="AppHeader__user-name">Organizer</span>
    </div>
  </div>
</header>

<style is:global>
  .AppHeader {
    background: var(--teal);
    color: var(--white);
    position: sticky;
    top: 0;
    z-index: 100;
    box-shadow: var(--shadow-sm);
  }

  .AppHeader__inner {
    display: flex;
    align-items: center;
    gap: 2rem;
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 var(--gutter);
    height: 3.5rem;
  }

  .AppHeader__brand {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-shrink: 0;
    text-decoration: none;
    color: inherit;
  }

  .AppHeader__brand-name {
    font: 700 1.125rem / 1 var(--font);
    letter-spacing: -0.01em;
  }

  .AppHeader__nav {
    display: flex;
    align-items: center;
    gap: 0;
    margin-left: 0.5rem;
  }

  .AppHeader__nav-link {
    padding: 0 0.875rem;
    height: 3.5rem;
    display: inline-flex;
    align-items: center;
    font: 500 0.9375rem / 1 var(--font);
    color: rgba(255, 255, 255, 0.75);
    text-decoration: none;
    border-bottom: 2px solid transparent;
    transition: color var(--transition), border-color var(--transition);

    &:hover {
      color: var(--white);
    }

    &:is(.AppHeader__nav-link--active),
    &[aria-current="page"] {
      color: var(--white);
      border-bottom-color: var(--white);
    }
  }

  .AppHeader__user {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-left: auto;
    font: 500 0.875rem / 1 var(--font);
    color: rgba(255, 255, 255, 0.85);
  }

  .AppHeader__user-avatar {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.15);
    border: 1.5px solid rgba(255, 255, 255, 0.3);
  }

  @container root (max-width: 47.999rem) {
    .AppHeader__nav {
      display: none;
    }
  }

  @container root (max-width: 29.999rem) {
    .AppHeader__user-name {
      display: none;
    }
  }
</style>
